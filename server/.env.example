# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://localhost:27017/kitchen_ecom

# JWT
JWT_ACCESS_SECRET=replace_with_long_random_string
JWT_REFRESH_SECRET=replace_with_another_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Arkesel SMS (leave ARKESEL_API_KEY blank for stub mode: OTPs printed to console)
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=KitchenLuv
ARKESEL_SANDBOX=false

# Paystack (leave blank to use stub mode: payments auto-succeed)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# OTP
OTP_LENGTH=6
OTP_EXPIRES_MINUTES=10

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
